# gosh-cli services configuration
# Copy to services.toml and adjust paths for your environment.
# Run `gosh init` to generate from this template.
#
# Use ${SECRET_KEY} to reference secrets from secrets.json.
# Use ${SECRET_KEY:generate} to auto-generate if missing.

# ── Memory server ────────────────────────────────────────────────────────────

[services.memory]
path = "/absolute/path/to/gosh-ai-memory"
python_module = "src.mcp_server"
port = 8765
venv = true
args = [
    "--data-dir", "./data",
    "--host", "127.0.0.1",
    "--server-token", "${MEMORY_SERVER_TOKEN:generate}",
    "--extraction-model", "openai/gpt-oss-20b",
    "--inference-model", "openai/gpt-oss-20b",
    "--judge-model", "openai/gpt-oss-20b",
    "--embed-model", "text-embedding-3-large",
    # For remote access, uncomment:
    # "--tls",
    # "--host", "0.0.0.0",
    # "--advertise-host", "YOUR_HOSTNAME_OR_IP",
]
depends_on = []
health_endpoint = "/health"

[services.memory.envs]

# ── Local agent (same machine as memory) ─────────────────────────────────────
# Started by `gosh start`. Connects to memory via localhost.

[services.alpha]
type = "agent"
binary = "/path/to/gosh-agent"
port = 8767
args = [
    "--memory-url", "http://127.0.0.1:8765/mcp",
    "--memory-token", "${MEMORY_SERVER_TOKEN}",
    "--watch",
    # "--watch-key", "my-namespace",
    "--watch-agent-id", "alpha",
    "--watch-swarm-id", "swarm_alpha",
    # For remote/TLS memory, replace --memory-url/--memory-token with:
    # "--join", "${MEMORY_JOIN_TOKEN}",
]
depends_on = ["memory"]
health_endpoint = "/health"

[services.alpha.envs]

# ── Remote agent (different machine) ─────────────────────────────────────────
# Not started by `gosh start` — runs on another machine.
# On the remote machine, start with the join token printed by memory:
#
#   gosh-agent --join <join-token> \
#     --watch --watch-agent-id beta --watch-swarm-id swarm_alpha
#
# Register it here so `gosh status` can health-check it:

# [services.beta]
# type = "agent"
# endpoint = "https://remote-machine:8767"
# health_endpoint = "/health"

# ── Reviewer agent (Codex CLI on another machine) ────────────────────────────
# Same pattern as remote agent. Start on the target machine:
#
#   gosh-agent --join <join-token> \
#     --watch --watch-agent-id reviewer --watch-swarm-id swarm_alpha

# [services.reviewer]
# type = "agent"
# endpoint = "https://reviewer-machine:8768"
# health_endpoint = "/health"
